# ==============================================
# AVATARLIVE ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in values
# ==============================================

# ---------- Anthropic (Claude) ----------
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ---------- Deepgram (STT) ----------
# Get from: https://console.deepgram.com/
DEEPGRAM_API_KEY=xxxxx

# ---------- D-ID (Avatar + TTS) ----------
# Get from: https://studio.d-id.com/account
DID_API_KEY=xxxxx
# Optional: Your D-ID WebRTC agent ID for real-time streaming
DID_AGENT_ID=agt_xxxxx

# ---------- Pinecone (Vector Store) ----------
# Get from: https://app.pinecone.io/
PINECONE_API_KEY=xxxxx
PINECONE_INDEX=avatarlive
# Environment: us-east-1-aws, eu-west-1-gcp, etc.
PINECONE_ENVIRONMENT=us-east-1-aws

# ---------- Supabase (Database + Auth) ----------
# Get from: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxx
SUPABASE_SERVICE_ROLE_KEY=xxxxx

# ---------- ElevenLabs (Optional - Voice Cloning) ----------
# Get from: https://elevenlabs.io/
ELEVENLABS_API_KEY=xxxxx
# Your cloned voice ID
ELEVENLABS_VOICE_ID=xxxxx

# ---------- App Configuration ----------
# Base URL for the app (used for PWA manifest)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Admin password for /admin route (simple auth)
ADMIN_PASSWORD=your-secure-admin-password

# ---------- Feature Flags ----------
# Enable/disable features
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_VIDEO_FALLBACK=true
